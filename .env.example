# Firebase Admin SDK (Service Account) - Primary
# Download JSON dari Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@xxxx.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"

# Firebase Client SDK (Web Config) - Fallback jika Admin SDK unavailable
# FIREBASE_API_KEY="AIzaSy..."
# FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# FIREBASE_MESSAGING_SENDER_ID="123456789"
# FIREBASE_APP_ID="1:123456789:web:abc123"

# Turso Database (Primary database - recommended over Firebase for Vercel)
TURSO_DATABASE_URL="libsql://your-database.aws-region.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Session Secret untuk JWT (WAJIB diganti dengan string unik untuk production!)
SESSION_SECRET="ganti_dengan_string_acak"

# Environment (development / production)
NODE_ENV="development"
