# Turso Database (Primary - untuk Vercel Production)
# Buat database di https://turso.tech, lalu isi credentials:
# TURSO_DATABASE_URL="libsql://your-database.aws-region.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Session Secret untuk JWT (WAJIB diganti dengan string unik untuk production!)
SESSION_SECRET="ganti_dengan_string_acak"

# Vercel Blob untuk penyimpanan file persistent (opsional)
# Dapatkan token dari Vercel Dashboard → Storage → Blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Environment
NODE_ENV="development"
